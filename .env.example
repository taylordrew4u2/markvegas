# Turso database URL (libsql://...)
TURSO_DB_URL=
TURSO_DATABASE_URL=

# Turso authentication token
TURSO_DB_AUTH_TOKEN=
TURSO_AUTH_TOKEN=

# Admin secret – all write API endpoints require Authorization: Bearer <ADMIN_SECRET>
# Defaults to "markvegas" when not set; change this before deploying publicly.
ADMIN_SECRET=

# Vercel Blob read/write token – required for /api/upload. Get this from the
# Vercel dashboard: Storage → Create Blob store → Connect to project. Vercel
# injects it automatically in production; set it locally for `vercel dev`.
BLOB_READ_WRITE_TOKEN=
